{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Satellite Evidence Pack v1",
  "type": "object",
  "required": [
    "schema_name",
    "schema_version",
    "artifact_policy",
    "benchmark_fixtures",
    "core_transform_refs",
    "input_kinds",
    "metadata",
    "output_schema_refs",
    "recall_policy",
    "redaction_policy",
    "report_sections",
    "support_policy"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_name": {
      "const": "software-satellite-evidence-pack-v1"
    },
    "schema_version": {
      "const": 1
    },
    "metadata": {
      "type": "object",
      "required": [
        "pack_id",
        "version",
        "title",
        "summary"
      ],
      "additionalProperties": false,
      "properties": {
        "pack_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "version": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "license": {
          "type": "string"
        }
      }
    },
    "input_kinds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "agent_session_bundle",
          "ci_log",
          "diff",
          "failure",
          "patch",
          "review_note",
          "software_work_event",
          "test_log",
          "transcript"
        ]
      },
      "uniqueItems": true
    },
    "artifact_policy": {
      "type": "object",
      "required": [
        "selected_roots",
        "path_mode",
        "link_policy",
        "missing_source_policy"
      ],
      "additionalProperties": false,
      "properties": {
        "selected_roots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "path_mode": {
          "const": "selected_roots_only"
        },
        "link_policy": {
          "const": "refuse_links"
        },
        "missing_source_policy": {
          "const": "block"
        }
      }
    },
    "recall_policy": {
      "type": "object",
      "required": [
        "mode",
        "max_items",
        "require_source_refs"
      ],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "agent_session",
            "failure_memory",
            "none"
          ]
        },
        "max_items": {
          "type": "integer",
          "minimum": 0
        },
        "require_source_refs": {
          "const": true
        }
      }
    },
    "support_policy": {
      "type": "object",
      "required": [
        "required_kernel",
        "requested_polarity",
        "require_source_linked_evidence",
        "require_support_kernel"
      ],
      "additionalProperties": false,
      "properties": {
        "required_kernel": {
          "const": "evidence_support_v1"
        },
        "requested_polarity": {
          "type": "string",
          "enum": [
            "positive",
            "negative",
            "risk",
            "diagnostic",
            "none"
          ]
        },
        "require_source_linked_evidence": {
          "const": true
        },
        "require_support_kernel": {
          "const": true
        }
      }
    },
    "report_sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "source"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "title": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "enum": [
              "benchmark_summary",
              "input_summary",
              "recall_summary",
              "support_kernel"
            ]
          }
        }
      }
    },
    "benchmark_fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "input_kind",
          "artifact_name",
          "fixture_text",
          "requested_polarity",
          "expected_support_class",
          "expected_can_support_decision"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "input_kind": {
            "type": "string",
            "enum": [
              "agent_session_bundle",
              "ci_log",
              "diff",
              "failure",
              "patch",
              "review_note",
              "software_work_event",
              "test_log",
              "transcript"
            ]
          },
          "artifact_name": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$"
          },
          "fixture_text": {
            "type": "string"
          },
          "requested_polarity": {
            "type": "string",
            "enum": [
              "positive",
              "negative",
              "risk",
              "diagnostic",
              "none"
            ]
          },
          "expected_support_class": {
            "type": "string",
            "enum": [
              "source_linked_prior",
              "negative_prior",
              "manual_pin_diagnostic",
              "unknown"
            ]
          },
          "expected_can_support_decision": {
            "type": "boolean"
          }
        }
      }
    },
    "redaction_policy": {
      "type": "object",
      "required": [
        "mode",
        "token_handling"
      ],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "const": "best_effort_local"
        },
        "token_handling": {
          "const": "redact_known_tokens"
        }
      }
    },
    "output_schema_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "agent_session_bundle.schema.json",
          "evidence_graph.schema.json",
          "evidence_support.schema.json",
          "review_memory_fixture.schema.json",
          "satellite_evidence_pack_v1.schema.json"
        ]
      },
      "uniqueItems": true
    },
    "core_transform_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "agent_session_intake",
          "artifact_capture",
          "evidence_lint",
          "markdown_report",
          "recall_failure",
          "redaction_report",
          "support_gate"
        ]
      },
      "uniqueItems": true
    }
  }
}
